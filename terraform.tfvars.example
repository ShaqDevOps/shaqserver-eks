region = "us-east-1"
cluster_name = "my-cluster"
instance_type = "t3.medium"
vpc_cidr = "20.0.0.0/16"
root_domain = "example.com"
additional_subdomains = ["app", "admin"]
wordwell_domain = "app.example.com"
wordwell_image = "your-registry/wordwell:latest"
app_name = "wordwell"
app_container_port = 8000
app_service_port = 8000
namespace = "default"
ingress_name = "main-ingress"
ingress_group_name = "example-group"
meowmart_image = "your-registry/meowmart:latest"
slide_backend_image = "your-registry/slide-backend:latest"
slide_frontend_image = "your-registry/slide-frontend:latest"
landing_page_image = "your-registry/landing-page:latest"
